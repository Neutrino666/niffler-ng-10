{
  "chrome": {
    "default": "145.0",
    "versions": {
      "145.0": {
        "image": "twilio/selenoid:chrome_stable_145",
        "port": "4444",
        "env": [
          "TZ=Europe/Moscow"
        ]
      }
    }
  },
  "firefox": {
    "default": "148.0",
    "versions": {
      "148.0": {
        "image": "twilio/selenoid:firefox_stable_148",
        "port": "4444",
